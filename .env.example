# Copia a .env (no se sube a Git) y reinicia SERVIR.bat
PORT=3000
HOST=127.0.0.1

# Token opcional para proteger GET/POST /api/organizacion
# Genera uno largo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORGANIZACION_TOKEN=

# Límite de tamaño del JSON al guardar (bytes). Por defecto 12 MB.
# MAX_BODY_BYTES=12582912
