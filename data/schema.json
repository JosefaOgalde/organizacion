{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrganizacionData",
  "description": "Estructura de datos para el organizador diario",
  "type": "object",
  "properties": {
    "clientes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "nombre", "tipo", "fechaLimite", "entregables", "prioridad"],
        "properties": {
          "id": { "type": "string" },
          "nombre": { "type": "string" },
          "tipo": { "enum": ["freelance", "fulltime", "personal"] },
          "color": { "type": "string" },
          "descripcion": { "type": "string" },
          "fechaInicio": { "type": "string", "format": "date" },
          "fechaLimite": { "type": "string", "format": "date" },
          "entregables": { "type": "string" },
          "horasSemanales": { "type": ["integer", "null"] },
          "prioridad": { "enum": ["alta", "media", "baja"] },
          "notas": { "type": "string" },
          "creado": { "type": "string", "format": "date" }
        }
      }
    },
    "tareas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "titulo", "clienteId", "fecha", "prioridad"],
        "properties": {
          "id": { "type": "string" },
          "titulo": { "type": "string" },
          "clienteId": { "type": "string" },
          "fecha": { "type": "string", "format": "date" },
          "horaInicio": { "type": "string" },
          "horaFin": { "type": "string" },
          "descripcion": { "type": "string" },
          "prioridad": { "enum": ["alta", "media", "baja"] },
          "estimadoMin": { "type": ["integer", "null"] },
          "completada": { "type": "boolean" },
          "pendiente": { "type": "boolean" },
          "fechaOriginal": { "type": "string", "format": "date" },
          "creado": { "type": "string", "format": "date" }
        }
      }
    },
    "ultimaVisita": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Última fecha en que se abrió la app; usada para mover tareas vencidas a pendientes"
    }
  }
}
